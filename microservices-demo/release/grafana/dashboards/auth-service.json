{
  "id": null,
  "uid": "auth-service-dashboard",
  "title": "Auth Service Metrics",
  "tags": ["auth", "microservices"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total HTTP Requests",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(http_requests_total{job=\"authservice\"})",
          "legendFormat": "Total Requests"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Auth Service Up",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=\"authservice\"}",
          "legendFormat": "Status"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"authservice\"}[1m])",
          "legendFormat": "{{method}} {{handler}} {{status_code}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request Duration (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"authservice\"}[1m]))",
          "legendFormat": "p95 latency"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Errors (4xx / 5xx)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"authservice\", status_code=~\"4..|5..\"}[1m])",
          "legendFormat": "{{status_code}} {{handler}}"
        }
      ]
    }
  ],
  "time": { "from": "now-30m", "to": "now" }
}
